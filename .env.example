EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# OCR.space API - Free OCR (25,000 requests/month, no billing)
# Get free key from: https://ocr.space/ocrapi
# Use 'helloworld' for testing (limited to 500 requests/hour)
EXPO_PUBLIC_OCR_SPACE_API_KEY=helloworld

# Use `expo start -c` or your preferred method to load env vars, or set them
# in your CI / hosting provider. Never commit the real `.env` to Git.
